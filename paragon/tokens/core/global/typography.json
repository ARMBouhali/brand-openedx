{
  "typography": {
    "font": {
      "family": {
        "$type": "fontFamily",
        "base": {
          "$value": "{typography.font.family.sans.serif}"
        },
        "sans": {
          "serif": {
            "$value": [
              "Product Sans",
              "Helvetica Neue",
              "Arial",
              "Noto Sans",
              "sans-serif",
              "Apple Color Emoji",
              "Segoe UI Emoji",
              "Segoe UI Symbol",
              "Noto Color Emoji"
            ]
          }
        }
      }
    }
  }
}
